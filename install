#!/usr/bin/env bash

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Warn if no backup exists
if [[ ! -d "$HOME/.dotfiles-backup" ]]; then
  echo "WARNING: No backup found at ~/.dotfiles-backup/"
  echo "Run ./backup.sh first to snapshot your current config."
  echo ""
  read -p "Continue without backup? [y/N] " answer
  [[ "$answer" =~ ^[Yy]$ ]] || exit 0
fi

if [[ "$(uname)" == "Darwin" ]]; then
  CONFIG="install-mac.conf.yaml"

  # Install Homebrew if not present
  if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi

  # Install dotbot if not present
  if ! command -v dotbot &>/dev/null; then
    echo "Installing dotbot..."
    brew install dotbot
  fi
else
  CONFIG="install-linux.conf.yaml"

  # Install dotbot if not present
  if ! command -v dotbot &>/dev/null; then
    echo "Installing dotbot via pip..."
    pip3 install dotbot
  fi
fi

echo ""
echo "This will create symlinks from the dotbot config ($CONFIG)."
echo "Existing symlinks will be replaced. Real files will NOT be overwritten."
echo ""
read -p "Proceed? [y/N] " answer
[[ "$answer" =~ ^[Yy]$ ]] || exit 0

dotbot -d "${BASEDIR}" -c "${CONFIG}" "${@}"
